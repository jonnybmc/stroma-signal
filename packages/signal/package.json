{
  "name": "@stroma-labs/signal",
  "version": "0.1.0",
  "description": "Browser instrumentation package for measuring real-user network, device, and performance tiers.",
  "license": "MIT",
  "author": "Jonathan Booysen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonnybmc/stroma-signal.git",
    "directory": "packages/signal"
  },
  "homepage": "https://github.com/jonnybmc/stroma-signal#readme",
  "bugs": {
    "url": "https://github.com/jonnybmc/stroma-signal/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jonathanbooysen"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "performance",
    "analytics",
    "signal",
    "ga4",
    "browser",
    "web-vitals",
    "rum",
    "real-user-monitoring",
    "performance-monitoring"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./ga4": {
      "types": "./dist/ga4/index.d.ts",
      "import": "./dist/ga4/index.mjs",
      "default": "./dist/ga4/index.mjs"
    },
    "./report": {
      "types": "./dist/report/index.d.ts",
      "import": "./dist/report/index.mjs",
      "default": "./dist/report/index.mjs"
    },
    "./summary": {
      "types": "./dist/summary/index.d.ts",
      "import": "./dist/summary/index.mjs",
      "default": "./dist/summary/index.mjs"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.mjs"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm -C ../.. build && pnpm -C ../.. check:release"
  },
  "devDependencies": {
    "@stroma-labs/signal-contracts": "workspace:*"
  }
}
