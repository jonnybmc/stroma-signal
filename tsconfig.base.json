{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@stroma-labs/signal-contracts": ["packages/signal-contracts/src/index.ts"],
      "@stroma-labs/signal": ["packages/signal/src/index.ts"],
      "@stroma-labs/signal/ga4": ["packages/signal/src/ga4/index.ts"],
      "@stroma-labs/signal/report": ["packages/signal/src/report/index.ts"]
    }
  }
}
